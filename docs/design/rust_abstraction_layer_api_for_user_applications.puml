package "opensovd_diag" {
    enum ErrorCode {
        <<Copy, Clone, Debug, PartialEq, Eq>>
        Unknown
        InternalError
    }

    entity "Result<T>" as DiagResult {
        type alias for std::result::Result<T, ErrorCode>
    }

    entity ByteSlice {
        <<type alias>>
        ByteSlice<'a> = &'a [u8]
    }

    entity ByteVec {
        <<type alias>>
        ByteVec = Vec<u8>
    }

    abstract class DiagnosticServicesCollection {
        no public methods are defined since lifetime control of contained diagnostic services is the only goal of this class
        Automatic cleanup on Drop
    }
}

